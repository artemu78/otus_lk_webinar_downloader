{
  "manifest_version": 3,
  "name": "OTUS Webinar Downloader",
  "version": "1.0.3",
  "description": "Downloads the public webinar recording for the current OTUS lesson.",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": ["activeTab", "downloads"],
  "host_permissions": ["https://otus.ru/*"],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_title": "Download OTUS webinar",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png"
    },
    "default_popup": "popup.html"
  }
}
