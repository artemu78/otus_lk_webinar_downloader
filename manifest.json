{
  "manifest_version": 3,
  "name": "Загрузчик вебинаров OTUS",
  "version": "1.0.8",
  "description": "Скачивает доступную запись вебинара для текущего занятия OTUS.",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": ["activeTab", "clipboardWrite", "downloads"],
  "host_permissions": ["https://otus.ru/*"],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_title": "Скачать вебинар OTUS",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png"
    },
    "default_popup": "popup.html"
  }
}
